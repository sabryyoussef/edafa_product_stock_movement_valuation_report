<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_movement_valuation_report_wizard_form" model="ir.ui.view">
        <field name="name">stock.movement.valuation.report.wizard.form</field>
        <field name="model">stock.movement.valuation.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Product Movement Valuation">
                <group>
                    <group string="Main Filters">
                        <field name="product_id" required="1"/>
                        <field name="company_id" required="1"/>
                        <field name="date_from" required="1"/>
                        <field name="date_to" required="1"/>
                    </group>
                    <group string="Location Scope">
                        <field name="warehouse_id"/>
                        <field name="location_id"/>
                        <field name="include_child_locations"/>
                    </group>
                    <group string="Display Options">
                        <field name="show_internal_transfers"/>
                        <field name="show_valuation"/>
                    </group>
                </group>
                <footer>
                    <button
                        name="action_print_pdf"
                        string="Print PDF"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_export_xlsx"
                        string="Export XLSX"
                        type="object"
                        class="btn-secondary"
                    />
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_movement_valuation_report_wizard" model="ir.actions.act_window">
        <field name="name">Product Movement Valuation</field>
        <field name="res_model">stock.movement.valuation.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_movement_valuation_report_wizard_form"/>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_stock_movement_valuation_report"
        name="Product Movement Valuation"
        parent="stock.menu_warehouse_report"
        action="action_stock_movement_valuation_report_wizard"
        sequence="260"
        groups="stock.group_stock_manager"
    />
</odoo>
